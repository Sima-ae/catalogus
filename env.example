# LOCAL Mac (Docker):  cp .env.local.example .env  →  npm run db:local
# LOCAL Mac (VPS DB):  npm run db:tunnel  + DATABASE_URL below
# VPS server:         cp .env.vps.example .env  →  https://superclones.cloud/catalogus/

NODE_ENV=development

# Leave empty locally. Production uses /catalogus (see .env.vps.example).
# NEXT_PUBLIC_BASE_PATH=
# NEXT_PUBLIC_APP_URL=http://localhost:3000

DATABASE_DRIVER=mariadb
DATABASE_URL=mysql://r_clones_cloud:Databaselogin2026@127.0.0.1:3306/r_clones_cloud

AUTH_DEV_FALLBACK=true

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Never commit real .env (gitignored).
