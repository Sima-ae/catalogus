# ── Local (Mac) ─────────────────────────────────────────────────────────────
#   cp .env.local.example .env
#   npm run dev              → http://localhost:3000/ (no /catalogus path)
#   npm run dev:local        → starts Docker MariaDB + dev server
#
# ── Production (VPS) ────────────────────────────────────────────────────────
#   cp .env.vps.example .env on the server
#   https://superclones.cloud/

# LOCAL values:
NODE_ENV=development
# When true, login works with built-in dev accounts if MariaDB is down (auth only).
# All catalog data (products, categories, orders, etc.) always requires MariaDB.
AUTH_DEV_FALLBACK=true
# Connect to the database:
#   npm run db:tunnel   — VPS database from your Mac
#   npm run dev:local   — local Docker MariaDB

# Site-wide access password (optional local testing)
SITE_ACCESS_COOKIE_SECRET=dev-site-access-secret-min-16-chars
DATABASE_DRIVER=mariadb
DATABASE_URL=mysql://supe_r_clones_cloud:localdev@127.0.0.1:3306/supe_r_clones_cloud

# PRODUCTION values (VPS only — see .env.vps.example):
# NODE_ENV=production
# NEXT_PUBLIC_APP_URL=https://superclones.cloud
# NEXT_PUBLIC_BASE_PATH=
# AUTH_DEV_FALLBACK=false

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
