# Use this ONLY in the www vhost document root if www has a separate public_html
# and https://www.superclones.cloud gives 500 with the full htaccess.example.
#
# Copy to: .../public_html for www.superclones.cloud/.htaccess
# (or add as Alias — same folder as apex is better in cPanel)

RewriteEngine On
RewriteRule ^(.*)$ https://superclones.cloud/$1 [R=301,L]
