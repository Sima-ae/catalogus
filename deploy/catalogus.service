# systemd unit — install on VPS:
#   sudo cp deploy/catalogus.service /etc/systemd/system/catalogus.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable catalogus
#   sudo systemctl start catalogus
#
# Runs as root so deploy scripts, npm, and public_html paths share one owner (no EACCES).

[Unit]
Description=Catalogus Next.js (superclones.cloud)
After=network.target mariadb.service mysql.service
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/var/www/superclones.cloud
Environment=NODE_ENV=production
EnvironmentFile=/var/www/superclones.cloud/.env
# Port 3001 — port 3000 is used by inkoop-autos (PM2) on this VPS
ExecStart=/usr/bin/npm run start -- -p 3001
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=catalogus

[Install]
WantedBy=multi-user.target
