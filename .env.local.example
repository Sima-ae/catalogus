# Local Mac — copy to .env:
#   cp .env.local.example .env
#
# Terminal 1:  npm run db:tunnel   (SSH as root → VPS MariaDB)
# Terminal 2:  npm run dev

NODE_ENV=development
AUTH_DEV_FALLBACK=true

DATABASE_DRIVER=mariadb
DATABASE_URL=mysql://supe_r_clones_cloud:YOUR_VPS_PASSWORD@127.0.0.1:3306/supe_r_clones_cloud
DB_CONNECTION_LIMIT=2

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

SITE_ACCESS_COOKIE_SECRET=replace-with-at-least-16-random-characters

NEXT_PUBLIC_APP_URL=https://superclones.cloud

# VPS product images (public_html/images). On the Mac, uploads are sent to production
# over HTTPS (no SSH key needed). Optional SSH fallback:
#   CATALOGUS_PUBLIC_HTML=/home/superclones.cloud/public_html
#   VPS_HOST=superclones.cloud
#   SSH_USER=root
#   VPS_SSH_KEY=/path/to/deploy-private-key-without-passphrase

# Optional — higher-quality automatic category translations (falls back to MyMemory if unset)
# DEEPL_API_KEY=your-deepl-auth-key
