# Local Mac — copy to .env:
#   cp .env.local.example .env
#
# Option A — no database (fastest):
#   npm run dev
#
# Option B — Docker MariaDB (full DB):
#   npm run dev:local

NODE_ENV=development
AUTH_DEV_FALLBACK=true

# Local Docker MariaDB (npm run dev:local) — not the VPS database
DATABASE_DRIVER=mariadb
DATABASE_URL=mysql://supe_r_clones_cloud:localdev@127.0.0.1:3306/supe_r_clones_cloud
# Keep low in dev to avoid "Too many connections" (default is 2 locally, max 10)
DB_CONNECTION_LIMIT=2

# Never set NEXT_PUBLIC_BASE_PATH or NEXT_PUBLIC_APP_URL for local dev.
# next.config.js serves http://localhost:3000/ at the site root.

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
