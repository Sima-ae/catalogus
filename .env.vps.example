# Use this .env ON THE VPS at /var/www/superclones.cloud/
# Build and run with: npm run build && npm run start

NODE_ENV=production

# CyberPanel docRoot (for scripts/sync-public-html.sh after each deploy)
CATALOGUS_PUBLIC_HTML=/home/superclones.cloud/public_html

# Public URL (app at site root — no /catalogus path)
NEXT_PUBLIC_APP_URL=https://superclones.cloud
# Leave empty or omit for root deploy; only set if you use a subpath again
NEXT_PUBLIC_BASE_PATH=

DATABASE_DRIVER=mariadb
# MUST be 127.0.0.1 on the VPS (MariaDB on same server). Copy password from CyberPanel → Databases.
# User + database name are usually supe_r_clones_cloud (with supe_ prefix).
DATABASE_URL=mysql://supe_r_clones_cloud:YOUR_PASSWORD@127.0.0.1:3306/supe_r_clones_cloud
# If password has @ # or % characters, use separate vars instead of DATABASE_URL:
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=supe_r_clones_cloud
# DB_PASSWORD=your_password
# DB_NAME=supe_r_clones_cloud

AUTH_DEV_FALLBACK=false

# Cap Next.js MariaDB pool (lower if import:worker runs on the same VPS)
DB_CONNECTION_LIMIT=8

# Optional Redis for shared TTL cache (shop-nav, catalog pages, count buckets).
# When unset, the app uses in-process memory only.
# REDIS_URL=redis://127.0.0.1:6379/0

# Import worker: only allow runs in this UTC hour window (e.g. 1-6 = 01:00–05:59 UTC).
# Pass --force on the CLI to override. Empty = always allowed.
# IMPORT_WORKER_ALLOWED_HOURS=1-6

# Optional marketing hosts → default category (same app/DB, scoped landing).
# CATEGORY_HOST_MAP=watches.superclones.cloud:WATCHES,perfumes.superclones.cloud:PERFUMES

# Sign site-access unlock cookies (16+ random characters)
# Required for site-wide access password (min 16 characters). After changing: sudo systemctl restart catalogus
SITE_ACCESS_COOKIE_SECRET=replace-with-at-least-16-random-characters

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
