# Use this .env ON THE VPS (app + MariaDB on same server)
# Build and run with: npm run build && npm run start

NODE_ENV=production

# Public URL (no trailing slash on origin; app lives under /catalogus)
NEXT_PUBLIC_APP_URL=https://superclones.cloud/catalogus
NEXT_PUBLIC_BASE_PATH=/catalogus

DATABASE_DRIVER=mariadb
DATABASE_URL=mysql://r_clones_cloud:Databaselogin2026@127.0.0.1:3306/r_clones_cloud

AUTH_DEV_FALLBACK=false

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
